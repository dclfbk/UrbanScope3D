# File esclusi dal deploy Vercel. Restano nel repo perche' sono sorgenti
# per gli script di preprocessing sotto scripts/, ma il MapViewer non li
# carica e non hanno motivo di finire nel bundle pubblico.

# DSM raw (Leonardo) - sorgente per scripts/build_dsm_ndsm.sh
public/data/DatiLeonardo_8-05-2026/
public/data/wetransfer_*.zip

# DTM raw - sorgente per scripts/build_terrain_rgb.sh
public/data/3)Terrain-DEM/

# Wind raster sorgente - il viewer carica solo processed/wind_overlay.{png,json}
public/data/04_Velocita_Vento.tif

# DBTR raw (1.2, 1.3, 1.5) - sorgenti per scripts/preprocess_dbtr.py
public/data/1)Buildings/1.2_DBTR_Edificio.json
public/data/1)Buildings/1.3_DBTR_Unita_Volumetrica.json
public/data/1)Buildings/1.5_DBTR_Cassone_Edilizio.json

# DBTR / DBTR-derived vegetation, non usati dal viewer (carica solo 2.1_trees_aoi.geojson)
public/data/2)Vegetation/2.1_Aree_Verdi_In_Manutenzione.geojson
public/data/2)Vegetation/2.2_Verde_Privato_Urbanizzato.geojson
public/data/2)Vegetation/*.xml
public/data/2)Vegetation/2.4.2_estraz_procons.json
public/data/2)Vegetation/2.5.2_estraz_procons.json

# LandUse raw shapefile (4 CRS paralleli, ~430 MB ciascuno) - il viewer
# carica solo 4.1_uso_suolo_2020_ed2023_aoi.geojson (gia' clippato all'AOI)
public/data/4)LandUse-GroundSurface/4.1_Uso_Suolo_Dettaglio_2020_ETRS89/
public/data/4)LandUse-GroundSurface/4.2_Uso_Suolo_Dettaglio_2020_GBO/
public/data/4)LandUse-GroundSurface/4.3_Uso_Suolo_Dettaglio_2020_UTMRER/
public/data/4)LandUse-GroundSurface/4.4_Uso_Suolo_Dettaglio_2020_RDN32/

# Doppi formati JSON dei dataset CSV/GeoJSON gia' inclusi
public/data/5)EnvironmentalData/5.1_Temperature_Bologna.json
public/data/5)EnvironmentalData/5.2_Centraline_Qualita_Aria.json
public/data/5)EnvironmentalData/5.2_centraline_qualita_aria.geojson

# Vecchi snapshot non piu' linkati dal viewer
public/data/buildings.geojson
public/data/temperature.geojson
